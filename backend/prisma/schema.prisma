generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum PlanType {
  STORE
  SHOP
  BUSINESS
}

enum BusinessMode {
  PRODUCT
  SERVICE
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  EMPLOYEE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  ORANGE_MONEY
  MTN_MOMO
  BANK_TRANSFER
  OTHER
}

enum BillingStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ─── BUSINESS CATEGORIES ─────────────────────────────────

enum BusinessCategory {
  // Product mode — Retail / Commerce
  CLOTHING
  SHOES
  PERFUMES
  COSMETICS
  HIJABS_ABAYAS
  JEWELRY
  BAGS
  ELECTRONICS
  HOUSE_PRODUCTS
  KITCHEN_PRODUCTS
  DECORATION
  EVENT_DECORATION
  CATERING
  MINI_MARKET
  WHOLESALE
  MIXED_SHOP
  // Product mode — Order-based
  CAKES
  FOOD_BUSINESS
  FOOD_DELIVERY
  HOME_COOKING
  WHATSAPP_SELLER
  MADE_TO_ORDER
  // Service mode
  DIGITAL_MARKETING
  FREELANCER
  AGENCY
  CONSULTANT
  DESIGNER
  DEVELOPER
  SOCIAL_MEDIA
  PRINTING
  BUSINESS_SERVICES
  // Catch-all
  OTHER
}

// ─── TENANT ──────────────────────────────────────────────

model Tenant {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  plan               PlanType           @default(STORE)
  businessMode       BusinessMode       @default(PRODUCT)
  businessCategories BusinessCategory[]
  phone              String?
  email              String?
  address            String?
  logo               String?
  currency           String             @default("XAF")
  language           String             @default("fr")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  invoiceColor       String?            @default("#2563eb")
  invoiceHeader      String?

  users              User[]
  products           Product[]
  orders             Order[]
  clients            Client[]
  invoices           Invoice[]
  deliveries         Delivery[]
  categories         Category[]
  subscription       Subscription?
  billingPayments    BillingPayment[]
  loyaltyRewards     LoyaltyReward[]
  stores             Store[]
  notifications      Notification[]
  dataExports        DataExport[]
  projects           Project[]
  recurringBillings  RecurringBilling[]

  @@map("tenants")
}

// ─── USER ────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole  @default(EMPLOYEE)
  isSuperAdmin  Boolean   @default(false)
  isActive      Boolean   @default(true)
  tenantId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  storeId       String?

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store?    @relation(fields: [storeId], references: [id])
  orders        Order[]   @relation("orderCreator")
  invoices      Invoice[] @relation("invoiceCreator")
  salesRecords  Order[]   @relation("orderSeller")
  projects      Project[] @relation("projectAssignee")

  @@map("users")
}

// ─── CATEGORY ────────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  name      String
  icon      String?
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, tenantId])
  @@map("categories")
}

// ─── PRODUCT (also used as Service Package when isService=true) ──

model Product {
  id              String           @id @default(uuid())
  name            String
  description     String?
  image           String?
  categoryId      String?
  tenantId        String
  businessType    BusinessCategory
  costPrice       Float            @default(0)
  sellingPrice    Float            @default(0)
  totalStock      Int              @default(0)
  lowStockAlert   Int              @default(5)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Adaptive fields stored as JSON
  barcode         String?
  sku             String?
  adaptiveFields  Json?

  // Service mode fields
  isService       Boolean          @default(false)
  duration        String?          // e.g. "1 month", "per session"
  recurringType   String?          // "one_time" | "monthly" | "quarterly" | "yearly"
  recurringPrice  Float?

  storeId         String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  store           Store?           @relation(fields: [storeId], references: [id])
  orderItems      OrderItem[]
  invoiceLineItems InvoiceLineItem[]
  recurringBillings RecurringBilling[]

  @@map("products")
}

// ─── CLIENT ──────────────────────────────────────────────

model Client {
  id             String    @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  loyaltyPoints  Int       @default(0)
  loyaltyTier    String    @default("BRONZE")
  totalSpent     Float     @default(0)
  totalOrders    Int       @default(0)
  lastVisit      DateTime?
  tenantId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders         Order[]
  invoices       Invoice[]
  deliveries     Delivery[]
  loyaltyRewards LoyaltyReward[]
  projects       Project[]
  recurringBillings RecurringBilling[]

  @@map("clients")
}

// ─── ORDER ───────────────────────────────────────────────

model Order {
  id              String        @id @default(uuid())
  reference       String
  status          OrderStatus   @default(PENDING)
  totalAmount     Float         @default(0)
  discount        Float         @default(0)
  taxAmount       Float         @default(0)
  finalAmount     Float         @default(0)
  amountPaid      Float         @default(0)
  amountRemaining Float         @default(0)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?
  tenantId        String
  clientId        String?
  createdById     String
  sellerId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client?       @relation(fields: [clientId], references: [id])
  createdBy       User          @relation("orderCreator", fields: [createdById], references: [id])
  seller          User?         @relation("orderSeller", fields: [sellerId], references: [id])
  items           OrderItem[]
  invoice         Invoice?
  delivery        Delivery?

  @@map("orders")
}

// ─── ORDER ITEM ──────────────────────────────────────────

model OrderItem {
  id          String  @id @default(uuid())
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float
  variant     String?
  orderId     String
  productId   String

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── INVOICE ─────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String
  totalAmount   Float
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)
  paymentStatus PaymentStatus @default(PENDING)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  tenantId      String
  orderId       String?       @unique
  projectId     String?
  clientId      String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order?        @relation(fields: [orderId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
  client        Client?       @relation(fields: [clientId], references: [id])
  createdBy     User          @relation("invoiceCreator", fields: [createdById], references: [id])
  payments      Payment[]
  lineItems     InvoiceLineItem[]

  @@map("invoices")
}

// ─── INVOICE LINE ITEM (for standalone invoices) ─────────

model InvoiceLineItem {
  id          String   @id @default(uuid())
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  totalPrice  Float

  invoiceId   String
  productId   String?

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("invoice_line_items")
}

// ─── PAYMENT ─────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  method        PaymentMethod @default(CASH)
  reference     String?
  notes         String?
  invoiceId     String
  createdAt     DateTime      @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── DELIVERY ────────────────────────────────────────────

model Delivery {
  id            String         @id @default(uuid())
  status        DeliveryStatus @default(PENDING)
  address       String
  phone         String?
  notes         String?
  deliveryDate  DateTime?
  deliveredAt   DateTime?
  tenantId      String
  orderId       String         @unique
  clientId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order          @relation(fields: [orderId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])

  @@map("deliveries")
}

// ─── PROJECT (SERVICE mode) ──────────────────────────────

model Project {
  id              String        @id @default(uuid())
  name            String
  description     String?
  status          ProjectStatus @default(ACTIVE)

  totalBudget     Float         @default(0)
  amountPaid      Float         @default(0)
  amountRemaining Float         @default(0)

  startDate       DateTime?
  deadline        DateTime?
  completedAt     DateTime?

  tenantId        String
  clientId        String?
  assignedToId    String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client?       @relation(fields: [clientId], references: [id])
  assignedTo      User?         @relation("projectAssignee", fields: [assignedToId], references: [id])

  milestones      ProjectMilestone[]
  invoices        Invoice[]

  @@map("projects")
}

// ─── PROJECT MILESTONE ───────────────────────────────────

model ProjectMilestone {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  amount      Float     @default(0)

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@map("project_milestones")
}

// ─── RECURRING BILLING (SERVICE mode) ────────────────────

model RecurringBilling {
  id              String   @id @default(uuid())
  amount          Float
  frequency       String   @default("monthly")
  nextBillingDate DateTime
  isActive        Boolean  @default(true)
  lastInvoiceId   String?

  tenantId        String
  clientId        String
  productId       String?

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client   @relation(fields: [clientId], references: [id])
  product         Product? @relation(fields: [productId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("recurring_billings")
}

// ─── SUBSCRIPTION (BILLING) ─────────────────────────────

model Subscription {
  id              String             @id @default(uuid())
  plan            PlanType           @default(STORE)
  status          SubscriptionStatus @default(TRIAL)
  priceMonthly    Int                @default(4900)
  startDate       DateTime           @default(now())
  endDate         DateTime
  trialEndsAt     DateTime?
  features        Json?
  tenantId        String             @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── BILLING PAYMENT ─────────────────────────────────────

model BillingPayment {
  id              String        @id @default(uuid())
  tenantId        String
  plan            String
  months          Int           @default(1)
  amountXAF       Int
  extraBranches   Int           @default(0)
  extraUsers      Int           @default(0)
  status          BillingStatus @default(PENDING)
  payToken        String?
  omOrderId       String?
  mode            String        @default("manual")
  confirmedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("billing_payments")
}

// ─── LOYALTY REWARD ──────────────────────────────────────

model LoyaltyReward {
  id              String   @id @default(uuid())
  name            String
  pointsRequired  Int
  discountPercent Float    @default(0)
  discountAmount  Float    @default(0)
  isActive        Boolean  @default(true)
  tenantId        String
  clientId        String?
  redeemedAt      DateTime?
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client?  @relation(fields: [clientId], references: [id])

  @@map("loyalty_rewards")
}

// ─── STORE (MULTI-STORE) ─────────────────────────────────

model Store {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  isMain          Boolean  @default(false)
  isActive        Boolean  @default(true)
  tenantId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]

  @@map("stores")
}

// ─── NOTIFICATION ────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  type       String
  title      String
  message    String
  isRead     Boolean  @default(false)
  metadata   Json?
  tenantId   String
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── DATA EXPORT ─────────────────────────────────────────

model DataExport {
  id         String   @id @default(uuid())
  type       String
  format     String   @default("csv")
  status     String   @default("pending")
  fileUrl    String?
  metadata   Json?
  tenantId   String
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("data_exports")
}
