generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum PlanType {
  STORE
  SHOP
  BUSINESS
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  EMPLOYEE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

// ─── BUSINESS CATEGORIES ─────────────────────────────────

enum BusinessCategory {
  CLOTHING
  SHOES
  PERFUMES
  COSMETICS
  HIJABS_ABAYAS
  JEWELRY
  BAGS
  FOOD
  CAKES
  KITCHEN_PRODUCTS
  OTHER
}

// ─── TENANT (STORE) ─────────────────────────────────────

model Tenant {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  plan              PlanType           @default(STORE)
  businessCategories BusinessCategory[]
  phone             String?
  email             String?
  address           String?
  logo              String?
  currency          String             @default("XAF")
  language          String             @default("fr")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  users             User[]
  products          Product[]
  orders            Order[]
  clients           Client[]
  invoices          Invoice[]
  deliveries        Delivery[]
  categories        Category[]
  subscription      Subscription?

  @@map("tenants")
}

// ─── USER ────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole  @default(EMPLOYEE)
  isActive      Boolean   @default(true)
  tenantId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders        Order[]   @relation("orderCreator")
  invoices      Invoice[] @relation("invoiceCreator")
  salesRecords  Order[]   @relation("orderSeller")

  @@map("users")
}

// ─── CATEGORY ────────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  name      String
  icon      String?
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, tenantId])
  @@map("categories")
}

// ─── PRODUCT ─────────────────────────────────────────────

model Product {
  id              String           @id @default(uuid())
  name            String
  description     String?
  image           String?
  categoryId      String?
  tenantId        String
  businessType    BusinessCategory
  costPrice       Float            @default(0)
  sellingPrice    Float            @default(0)
  totalStock      Int              @default(0)
  lowStockAlert   Int              @default(5)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Adaptive fields stored as JSON
  // Shoes: { brand, color, sizes: [{ size: "42", stock: 5 }] }
  // Clothing: { category, color, sizes: [{ size: "M", stock: 3 }] }
  // Perfumes: { brand, volume: "100ml" }
  // Cakes: { flavors: [...], sizes: [...] }
  // Food: { menuItems: [...] }
  adaptiveFields  Json?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]

  @@map("products")
}

// ─── CLIENT ──────────────────────────────────────────────

model Client {
  id            String    @id @default(uuid())
  name          String
  phone         String?
  email         String?
  address       String?
  loyaltyPoints Int       @default(0)
  totalSpent    Float     @default(0)
  totalOrders   Int       @default(0)
  tenantId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders        Order[]
  invoices      Invoice[]
  deliveries    Delivery[]

  @@map("clients")
}

// ─── ORDER ───────────────────────────────────────────────

model Order {
  id              String        @id @default(uuid())
  reference       String
  status          OrderStatus   @default(PENDING)
  totalAmount     Float         @default(0)
  discount        Float         @default(0)
  taxAmount       Float         @default(0)
  finalAmount     Float         @default(0)
  amountPaid      Float         @default(0)
  amountRemaining Float         @default(0)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?
  tenantId        String
  clientId        String?
  createdById     String
  sellerId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client?       @relation(fields: [clientId], references: [id])
  createdBy       User          @relation("orderCreator", fields: [createdById], references: [id])
  seller          User?         @relation("orderSeller", fields: [sellerId], references: [id])
  items           OrderItem[]
  invoice         Invoice?
  delivery        Delivery?

  @@map("orders")
}

// ─── ORDER ITEM ──────────────────────────────────────────

model OrderItem {
  id          String  @id @default(uuid())
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float
  variant     String? // e.g. "Size: M, Color: Blue" or "Pointure: 42"
  orderId     String
  productId   String

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── INVOICE ─────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String
  totalAmount   Float
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)
  paymentStatus PaymentStatus @default(PENDING)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  tenantId      String
  orderId       String        @unique
  clientId      String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order         @relation(fields: [orderId], references: [id])
  client        Client?       @relation(fields: [clientId], references: [id])
  createdBy     User          @relation("invoiceCreator", fields: [createdById], references: [id])
  payments      Payment[]

  @@map("invoices")
}

// ─── PAYMENT ─────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  method        PaymentMethod @default(CASH)
  reference     String?
  notes         String?
  invoiceId     String
  createdAt     DateTime      @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── DELIVERY ────────────────────────────────────────────

model Delivery {
  id            String         @id @default(uuid())
  status        DeliveryStatus @default(PENDING)
  address       String
  phone         String?
  notes         String?
  deliveryDate  DateTime?
  deliveredAt   DateTime?
  tenantId      String
  orderId       String         @unique
  clientId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order          @relation(fields: [orderId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])

  @@map("deliveries")
}

// ─── SUBSCRIPTION (BILLING) ─────────────────────────────

model Subscription {
  id            String             @id @default(uuid())
  plan          PlanType           @default(STORE)
  status        SubscriptionStatus @default(TRIAL)
  priceMonthly  Int                @default(4900)
  startDate     DateTime           @default(now())
  endDate       DateTime
  trialEndsAt   DateTime?
  tenantId      String             @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
