# Database (provided by Railway PostgreSQL addon)
DATABASE_URL="postgresql://postgres:password@localhost:5432/kabrak_store?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3001
NODE_ENV=production

# Frontend URL(s) for CORS - comma-separated for multiple origins
FRONTEND_URL="https://kabrak-store.vercel.app"

# Orange Money (optional - for real payment integration)
# OM_MERCHANT_KEY=""
# OM_API_TOKEN=""
# OM_MERCHANT_NUMBER="+237 655 806 851"
# OM_USSD_CODE="#150*46*1341156#"

# OpenAI API (required for AI reports)
OPENAI_API_KEY="your-openai-api-key-here"
